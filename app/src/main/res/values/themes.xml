<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.Cursive" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@color/cream</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/cream</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Default fonts -->
        <item name="android:fontFamily">serif</item>
        <item name="fontFamily">serif</item>
    </style>

    <style name="Theme.Cursive" parent="Base.Theme.Cursive" />

    <!-- Cursive Text Style (for "Cursive" app name) -->
    <style name="CursiveTextStyle">
        <item name="android:fontFamily">cursive</item>
        <item name="android:textStyle">italic</item>
    </style>

    <!-- Elegant Title Style -->
    <style name="ElegantTitleStyle">
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body Text Style -->
    <style name="BodyTextStyle">
        <item name="android:fontFamily">serif</item>
    </style>
    <!-- Calendar Theme -->
    <style name="CalendarTheme" parent="Theme.Cursive">
        <item name="colorAccent">@color/primary</item>
    </style>
    <style name="ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>


</resources>