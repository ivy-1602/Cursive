<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/cream">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Entries"
            android:fontFamily="cursive"
            android:textStyle="italic"
            android:letterSpacing="-0.05"
            android:textColor="@color/cream"
            android:textSize="24sp"
            android:layout_gravity="center_vertical" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Search Bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="Search entries..."
        app:boxBackgroundColor="@color/card_background"
        app:boxStrokeColor="@color/primary"
        app:hintTextColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textColor="@color/text_primary"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupMoodFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="false"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checked="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHappy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Happy"
                app:chipBackgroundColor="@color/mood_happy"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCalm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calm"
                app:chipBackgroundColor="@color/mood_calm"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNeutral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neutral"
                app:chipBackgroundColor="@color/mood_neutral"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sad"
                app:chipBackgroundColor="@color/mood_sad"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAnxious"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anxious"
                app:chipBackgroundColor="@color/mood_anxious"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Entries Count -->
    <TextView
        android:id="@+id/tvEntriesCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:text="0 entries"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- RecyclerView for All Entries -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAllEntries"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No entries yet"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Start writing to see your entries here"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>


</LinearLayout>